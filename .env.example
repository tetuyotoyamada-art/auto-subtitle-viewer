# Google Gemini API (required)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# Whisper settings (per-PC — Web UI reads these via GET /api/config)
# Defaults below are safe for CPU / first-time setup.
# Uncomment the GPU block on machines with CUDA 12 + recent NVIDIA drivers.

WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# GPU PC (after: pip install -r requirements-cuda.txt)
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16

# Optional: suppress Hugging Face symlink warning on Windows
# HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Phase 2: API server (optional)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
